                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;\nflowchart TD\n    A([Start]) --&gt; B[Open BandSync App]\n    B --&gt; C{Logged in}\n\n    C -- No --&gt; D[Sign up or login]\n    D --&gt; E[Load user profile]\n    C -- Yes --&gt; E\n\n    E --&gt; F[Select create or join band]\n    F --&gt; G{Choose action}\n\n    G --&gt; H[Manage songs]\n    H --&gt; H1[Add or edit lyrics and chords]\n    H1 --&gt; H2{Upload audio}\n    H2 -- Yes --&gt; H3[Send audio for analysis]\n    H3 --&gt; H4[Receive key tempo chords]\n    H4 --&gt; H5[Save song]\n    H2 -- No --&gt; H5\n    H5 --&gt; G\n\n    G --&gt; I[Manage setlists]\n    I --&gt; I1[Pick songs]\n    I1 --&gt; I2[Save setlist]\n    I2 --&gt; G\n\n    G --&gt; J[Manage events]\n    J --&gt; J1[Enter date time location]\n    J1 --&gt; J2[Attach setlist optional]\n    J2 --&gt; J3[Save event]\n    J3 --&gt; G\n\n    G --&gt; K[View calendar and library]\n    K --&gt; G\n\n    G --&gt; L{Logout}\n    L -- No --&gt; G\n    L -- Yes --&gt; M([End])\n&quot;&#xa;}" id="9">
