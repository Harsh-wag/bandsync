                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;\nsequenceDiagram\n    actor U as User\n    participant A as Flutter App\n    participant SA as Supabase Auth\n    participant DB as Supabase DB\n    participant AS as Audio Analysis Service\n\n    U-&gt;&gt;A: Login(email, password)\n    A-&gt;&gt;SA: authenticate()\n    SA--&gt;&gt;A: session + userId\n\n    U-&gt;&gt;A: Create/Join Band\n    A-&gt;&gt;DB: insert/select bands\n    DB--&gt;&gt;A: band data\n\n    U-&gt;&gt;A: Upload Song + Audio File\n    A-&gt;&gt;AS: POST /analyze (audio)\n    AS--&gt;&gt;A: tempo, key, chords\n\n    A-&gt;&gt;DB: insert song(title, lyrics, chords, key, tempo, bandId)\n    DB--&gt;&gt;A: song saved\n\n    U-&gt;&gt;A: Create Setlist\n    A-&gt;&gt;DB: insert setlist(songIds, bandId)\n    DB--&gt;&gt;A: setlist saved\n\n    U-&gt;&gt;A: Schedule Event\n    A-&gt;&gt;DB: insert event(setlistId, startTime, location)\n    DB--&gt;&gt;A: event saved\n\n    A--&gt;&gt;U: Show updated library + calendar\n\n&quot;&#xa;}" id="8">
