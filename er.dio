                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;\nclassDiagram\n    class User {\n        +String id\n        +String name\n        +String email\n        +DateTime createdAt\n    }\n\n    class Band {\n        +String id\n        +String name\n        +String inviteCode\n        +String createdBy\n        +DateTime createdAt\n    }\n\n    class BandMember {\n        +String id\n        +String bandId\n        +String userId\n        +String role\n        +DateTime joinedAt\n    }\n\n    class Song {\n        +String id\n        +String bandId\n        +String title\n        +String artist\n        +String album\n        +String lyrics\n        +String chords\n        +String key\n        +int tempo\n        +String filePath\n        +DateTime createdAt\n        +String createdBy\n    }\n\n    class Setlist {\n        +String id\n        +String bandId\n        +String name\n        +List~String~ songIds\n        +DateTime createdAt\n        +String createdBy\n    }\n\n    class Event {\n        +String id\n        +String bandId\n        +String title\n        +String description\n        +String location\n        +DateTime startTime\n        +DateTime endTime\n        +String setlistId\n        +DateTime createdAt\n        +String createdBy\n    }\n\n    class AudioAnalysisService {\n        +analyzeAudio(file) Map\n    }\n\n    class LibraryProvider {\n        +addSong(song)\n        +updateSong(song)\n        +deleteSong(songId)\n        +addSetlist(setlist)\n    }\n\n    class EventProvider {\n        +addEvent(event)\n        +updateEvent(event)\n        +deleteEvent(eventId)\n    }\n\n    User \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Band : creates\n    User \&quot;1\&quot; --&gt; \&quot;0..*\&quot; BandMember : joins\n    Band \&quot;1\&quot; --&gt; \&quot;0..*\&quot; BandMember : has\n    Band \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Song : contains\n    Band \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Setlist : contains\n    Band \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Event : schedules\n    Setlist \&quot;1\&quot; --&gt; \&quot;0..*\&quot; Event : assignedTo\n    LibraryProvider ..&gt; Song : manages\n    LibraryProvider ..&gt; Setlist : manages\n    EventProvider ..&gt; Event : manages\n    AudioAnalysisService ..&gt; Song : updates key/tempo/chords\n&quot;&#xa;}" id="7">
