                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;\nflowchart LR\n    A[Band Member]\n    B[Band Admin]\n    S((Sign Up / Login))\n    P((Manage Profile))\n    MB((Create Band))\n    JB((Join Band))\n    MM((Manage Members))\n    MS((Manage Songs))\n    MA((Upload Audio &amp; Analyze))\n    MSL((Create/Manage Setlists))\n    ME((Create/Manage Events))\n    V((View Calendar/Library))\n\n    B --- A\n\n    A --&gt; S\n    A --&gt; P\n    A --&gt; JB\n    A --&gt; MS\n    A --&gt; MA\n    A --&gt; MSL\n    A --&gt; ME\n    A --&gt; V\n\n    B --&gt; MB\n    B --&gt; MM\n\n    MA -. includes .-&gt; MS\n    MSL -. includes .-&gt; MS\n    ME -. includes .-&gt; MSL&quot;&#xa;}" id="6">
